# Copy this file to .streamlit/secrets.toml and fill in real values.
# .streamlit/secrets.toml is gitignored. Never commit real values.
#
# Run scripts/get_refresh_token.py once to generate client_id, client_secret,
# and refresh_token. See SETUP_GDRIVE.md for the full procedure.

[gdrive]
client_id = "REPLACE_WITH_OAUTH_CLIENT_ID.apps.googleusercontent.com"
client_secret = "REPLACE_WITH_OAUTH_CLIENT_SECRET"
refresh_token = "REPLACE_WITH_REFRESH_TOKEN_FROM_HELPER_SCRIPT"
